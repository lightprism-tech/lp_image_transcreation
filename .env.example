# Image Transcreation Pipeline - Environment Configuration
# Copy to .env and customize: cp .env.example .env
# Docker Compose loads this file into the container (env_file: .env).

# Application
PERCEPTION_ENV=development
DEBUG=true

# Paths (local: relative to project root; Docker: overridden in docker-compose to /app/...)
MODELS_DIR=./models
DATA_DIR=./data
CACHE_DIR=./cache
OUTPUT_DIR=./data/output

# Docker cache paths.
# docker-compose.yml overrides these to /app/cache/... and mounts ./cache:/app/cache,
# so downloaded BLIP/CLIP/OWL-ViT/Transformers/PaddleOCR/Torch artifacts are reused.
# For local runs, leave unset unless you want to force a custom cache location.
# HF_HOME=./cache/huggingface
# HF_HUB_CACHE=./cache/huggingface/hub
# TRANSFORMERS_CACHE=./cache/huggingface/transformers
# TORCH_HOME=./cache/torch
# XDG_CACHE_HOME=./cache/xdg
# PADDLE_HOME=./cache/paddle
# PADDLEOCR_HOME=./cache/paddleocr
# YOLO_CONFIG_DIR=./cache/ultralytics
# MPLCONFIGDIR=./cache/matplotlib

# Model Configuration
BLIP_MODEL=Salesforce/blip-image-captioning-large
BLIP_MODEL_API_KEY=your_blip_api_key_here
CLIP_MODEL=openai/clip-vit-large-patch14
DETR_MODEL=facebook/detr-resnet-50
VIT_DETECTOR_MODEL=google/owlv2-large-patch14-ensemble

# Docker build-time model preloading.
# Keep disabled by default; runtime downloads are saved under ./cache and reused.
PRELOAD_BLIP_MODEL=0
PRELOAD_VIT_DETECTOR=0

# Detection Thresholds
OBJECT_THRESHOLD=0.5
TEXT_THRESHOLD=0.6
CLASSIFICATION_THRESHOLD=0.7
DETR_THRESHOLD=0.5
ENABLE_DETR=false
DETECTOR_HYBRID_MODE=yolo_only
HYBRID_DUPLICATE_IOU=0.55

# Processing
BATCH_SIZE=1
OCR_GPU=false

# Output
SAVE_DEBUG=true
LOG_LEVEL=INFO

# LLM (Stage 2: reasoning) - choose exactly one provider profile below.
# Do not define both Groq and Azure provider blocks at the same time.

# Option A: Groq (recommended default for Stage 2 reasoning)
LLM_PROVIDER=groq
LLM_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
# Stage 2 policy: false means KG first, then Groq proposes localized candidates when KG has no match.
REASONING_STRICT_KB_GROUNDED_TRANSFORMS=false
# Optional dynamic token overrides for Stage 2 heuristics
# REASONING_SCENE_OVERRIDE_TOKENS=western,european,american,burger,pizza
# REASONING_PLACEHOLDER_TEXT_TOKENS=lorem,ipsum,dolor,amet,consectetur
# REASONING_ENABLE_LLM_PLACEHOLDER_CLASSIFIER=true

# Stage 2 + Stage 3 split setup (recommended)
# Stage 2 reasoning uses Groq (set above with LLM_PROVIDER=groq).
# Stage 3 image edits use Azure GPT Image.
# AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-2
# AZURE_OPENAI_IMAGES_DEPLOYMENT=gpt-image-2
# AZURE_OPENAI_IMAGE_API_VERSION=2025-04-01-preview
# GPT_IMAGE_QUALITY=medium
# GPT_IMAGE_OUTPUT_FORMAT=png
# GPT_IMAGE_TIMEOUT_SECONDS=180

# Option B: Azure for Stage 2 reasoning instead of Groq
# Set LLM_PROVIDER=azure only if your Azure chat deployment exists and is reachable.
# AZURE_OPENAI_DEPLOYMENT must be a deployed chat model name in your Azure resource.
# Example deployment names are resource-specific and may not literally be "gpt-4o".
# LLM_PROVIDER=azure
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Azure AI Foundry FLUX.2-pro (Black Forest Labs) image generation
# AZURE_FLUX_IMAGE_URL=https://YOUR_RESOURCE.services.ai.azure.com/providers/blackforestlabs/v1/flux-2-pro?api-version=preview
# AZURE_FLUX_MODEL=FLUX.2-pro
