{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Scene Perception Schema",
  "type": "object",
  "required": [
    "metadata",
    "image_type",
    "scene",
    "visual_regions",
    "text_regions",
    "layout",
    "text"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "image_path": {
          "type": "string"
        },
        "image_name": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "pipeline_version": {
          "type": "string"
        }
      },
      "required": [
        "image_path",
        "timestamp"
      ]
    },
    "image_type": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "description": "Model-derived image modality. This is open vocabulary and must not be constrained to fixed labels."
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "scene": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "setting": {
          "type": "string"
        },
        "mood": {
          "type": "string"
        },
        "activity": {
          "type": "string"
        },
        "confidence": {
          "type": "number"
        },
        "visual_context": {
          "type": "object",
          "properties": {
            "source": {
              "type": "string"
            },
            "generated_fields": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "image_type_hint": {
              "type": "string"
            },
            "ocr_text_sample": {
              "type": "string"
            },
            "prompt_context": {
              "type": "string"
            }
          }
        }
      }
    },
    "objects": {
      "type": "array",
      "items": {
        "$ref": "object_schema.json"
      }
    },
    "visual_regions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 0
          },
          "type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "semantic_role": {
            "type": "string"
          },
          "bbox": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "minItems": 4,
            "maxItems": 4
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "quality_flags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "text_regions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 0
          },
          "role": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "bbox": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "minItems": 4,
            "maxItems": 4
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "layout": {
      "type": "object",
      "properties": {
        "structure": {
          "type": "string"
        },
        "image_type": {
          "type": "string"
        },
        "text_role_counts": {
          "type": "object"
        },
        "visual_region_type_counts": {
          "type": "object"
        },
        "image_shape": {
          "type": "array"
        }
      }
    },
    "faces": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "bbox": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "minItems": 4,
            "maxItems": 4
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "text": {
      "type": "object",
      "properties": {
        "regions": {
          "type": "array"
        },
        "extracted": {
          "type": "array"
        },
        "full_text": {
          "type": "string"
        },
        "typography": {
          "type": "object",
          "properties": {
            "font_families": {
              "type": "array"
            },
            "font_weights": {
              "type": "object"
            },
            "avg_font_size": {
              "type": "number"
            },
            "styled_regions": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "object_links": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text_index": {
                "type": "integer",
                "minimum": 0
              },
              "object_index": {
                "type": "integer",
                "minimum": -1
              },
              "overlap_iou": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        }
      }
    },
    "quality_summary": {
      "type": "object",
      "properties": {
        "object_count": {
          "type": "integer",
          "minimum": 0
        },
        "face_count": {
          "type": "integer",
          "minimum": 0
        },
        "text_region_count": {
          "type": "integer",
          "minimum": 0
        },
        "ocr_text_count": {
          "type": "integer",
          "minimum": 0
        },
        "linked_text_count": {
          "type": "integer",
          "minimum": 0
        },
        "object_avg_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "text_region_avg_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "ocr_avg_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "sam_enabled": {
          "type": "boolean"
        },
        "sam_available": {
          "type": "boolean"
        },
        "sam_reason": {
          "type": "string"
        },
        "sam_segmented_object_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}