{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Object Schema",
    "type": "object",
    "required": [
        "id",
        "bbox"
    ],
    "properties": {
        "id": {
            "type": "integer",
            "minimum": 0
        },
        "bbox": {
            "type": "array",
            "items": {
                "type": "number"
            },
            "minItems": 4,
            "maxItems": 4,
            "description": "Bounding box coordinates [x1, y1, x2, y2]"
        },
        "class_name": {
            "type": "string",
            "description": "Legacy compatibility label derived from model caption when available; may be unknown_visual_region when uncertain."
        },
        "label": {
            "type": "string"
        },
        "original_class_name": {
            "type": "string"
        },
        "detector_label": {
            "type": "string"
        },
        "detector_backend": {
            "type": "string"
        },
        "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
        },
        "fused_confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
        },
        "quality_flags": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "caption": {
            "type": "string",
            "description": "Natural language description of the object"
        },
        "caption_candidates": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "prompt": {
                        "type": "string"
                    },
                    "caption": {
                        "type": "string"
                    },
                    "source": {
                        "type": "string"
                    }
                }
            }
        },
        "caption_source": {
            "type": "string"
        },
        "segmentation": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "source": {
                    "type": "string"
                },
                "reason": {
                    "type": "string"
                },
                "score": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "area_px": {
                    "type": "integer",
                    "minimum": 0
                },
                "area_ratio": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "polygon": {
                    "type": "array",
                    "items": {
                        "type": "array",
                        "items": {
                            "type": "number"
                        },
                        "minItems": 2,
                        "maxItems": 2
                    }
                }
            }
        },
        "attributes": {
            "type": "object",
            "properties": {
                "colors": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "emotion": {
                    "type": "string"
                },
                "clothing": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "pose": {
                    "type": "string"
                },
                "age": {
                    "type": "string"
                },
                "gender": {
                    "type": "string"
                }
            }
        }
    }
}